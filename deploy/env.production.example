# Copy this to backend/.env on the VM and fill in real values.
# cp deploy/env.production.example backend/.env

# App
APP_NAME="Test Case Assignment & Tracking Platform"
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
# Same-origin via Nginx, so CORS is not strictly needed. Listed for safety.
# NOTE: must be a JSON array (pydantic-settings v2 JSON-decodes List fields).
BACKEND_CORS_ORIGINS=["http://sfthyd158.silabs.com","http://10.207.132.78"]

# --- Database ---
# Default: SQLite (simplest). Note the FOUR slashes = absolute path.
DATABASE_URL=sqlite:////opt/testmgmt/data/test_tracker.db
# Recommended for a shared multi-user server: PostgreSQL
# DATABASE_URL=postgresql+psycopg2://testmgmt:CHANGE_ME@localhost:5432/test_tracker

# --- Security (CHANGE THESE) ---
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# --- First admin (created automatically on first startup) ---
FIRST_ADMIN_EMAIL=admin@silabs.com
FIRST_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
FIRST_ADMIN_NAME=Administrator

# --- JIRA (optional) ---
JIRA_BASE_URL=
JIRA_PROJECT_KEY=

# --- TestRail integration (Sync from TestRail button) ---
TESTRAIL_URL=https://siliconlabsconnectivitysqa.testrail.io
TESTRAIL_USER=
TESTRAIL_PASSWORD=
# Generated artifacts MUST use Linux paths (the defaults are Windows paths):
MASTER_LIST_OUTPUT=/opt/testmgmt/data/Master_Project_List.xlsx
ASSIGNMENT_SHEET_OUTPUT=/opt/testmgmt/data/Assigned_Test_Cases.xlsx
