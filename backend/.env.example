# App
APP_NAME="Test Case Assignment & Tracking Platform"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
# For PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/test_tracker
# For local quickstart without Postgres, SQLite is used by default:
DATABASE_URL=sqlite:///./test_tracker.db

# Security
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Seed admin
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=admin123
FIRST_ADMIN_NAME=Administrator

# JIRA (via MCP). Leave blank to run in stub mode.
JIRA_BASE_URL=
JIRA_PROJECT_KEY=

# TestRail integration (Sync from TestRail button)
TESTRAIL_URL=https://siliconlabsconnectivitysqa.testrail.io
TESTRAIL_USER=
TESTRAIL_PASSWORD=
# Tip: prefer a TestRail API key over your account password.
MASTER_LIST_OUTPUT=C:/Automation_Tracking_Project/Test_Rail_Master_Data/psmr-tool/automation_data/Master_Project_List.xlsx
